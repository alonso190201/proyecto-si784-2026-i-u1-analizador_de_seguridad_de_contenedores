# Container Security Analyzer - Environment Configuration

# Flask settings
FLASK_ENV=development
FLASK_DEBUG=true

# Security
SECRET_KEY=change-this-in-production-immediately
# Optional: when set, API calls must include X-API-Token or Authorization: Bearer
# APP_AUTH_TOKEN=

# Application limits
# MAX_CONTENT_LENGTH=16777216  # 16MB max upload size
# HISTORY_MAX_SIZE=50          # Number of history items to keep in local JSON
# HISTORY_FILE=history.json
# STORE_FULL_HISTORY=true      # Stores sanitized findings; set false for summaries only
